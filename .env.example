# ─── Anthropic API ───
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Cisco Modeling Labs ───
CML_HOST=https://your-cml-host.example.com
CML_USERNAME=admin
CML_PASSWORD=your-cml-password

# ─── Network device credentials (for testbed devices) ───
DEVICE_USERNAME=admin
DEVICE_PASSWORD=cisco
DEVICE_ENABLE_PASSWORD=cisco

# ─── Ollama (local LLM serving) ───
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_LLAMA=llama3.1:8b-instruct-q5_K_M
OLLAMA_MODEL_QWEN=qwen2.5:7b-instruct-q5_K_M

# ─── Vector DB ───
CHROMA_PERSIST_DIR=./chroma_db

# ─── Eval / experiment tracking ───
WANDB_API_KEY=
WANDB_PROJECT=netagent
WANDB_ENTITY=

# ─── Logging ───
LOG_LEVEL=INFO
AUDIT_LOG_DIR=./logs/audit

# ─── Safety ───
APPROVAL_REQUIRED_FOR_WRITE=true
DRY_RUN=false
